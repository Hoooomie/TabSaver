{
  "manifest_version": 3,
  "name": "TabSaver - 标签页保存器",
  "version": "1.0.0",
  "description": "自动记录Chrome标签页，配合TabSaver桌面端一键恢复",
  "permissions": [
    "tabs",
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
